{
  "name": "fostudio",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "start": "node .output/server/index.mjs",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "analytics:ingest": "pnpm exec tsx admin/analytics/scripts/ingest_memberships.ts && pnpm exec tsx admin/analytics/scripts/ingest_bookings.ts && pnpm exec tsx admin/analytics/scripts/ingest_ads.ts && pnpm exec tsx admin/analytics/scripts/normalize_all.ts",
    "analytics:compute": "pnpm exec tsx admin/analytics/scripts/compute_metrics.ts && pnpm exec tsx admin/analytics/scripts/compute_trends.ts && pnpm exec tsx admin/analytics/scripts/compute_alerts.ts",
    "analytics:report": "pnpm exec tsx admin/analytics/scripts/build_weekly_report.ts",
    "analytics:publish": "pnpm exec tsx admin/analytics/scripts/publish_outputs.ts",
    "analytics:all": "pnpm analytics:ingest && pnpm analytics:compute && pnpm analytics:report && pnpm analytics:publish",
    "analytics:remote:run": "pnpm exec tsx admin/analytics/scripts/remote_analytics.ts run",
    "analytics:remote:outputs": "pnpm exec tsx admin/analytics/scripts/remote_analytics.ts outputs"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@fullcalendar/vue3": "^6.1.20",
    "@iconify-json/lucide": "^1.2.100",
    "@iconify-json/simple-icons": "^1.2.75",
    "@nuxt/content": "^3.12.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.6.0",
    "@nuxtjs/supabase": "2.0.4",
    "@standard-schema/spec": "^1.1.0",
    "@supabase/supabase-js": "^2.101.1",
    "@vueuse/nuxt": "^14.2.1",
    "better-sqlite3": "^12.8.0",
    "debug": "^4.4.3",
    "luxon": "^3.7.2",
    "nuxt": "^4.4.2",
    "nuxt-og-image": "^6.3.0",
    "nuxt-studio": "^1.5.1",
    "parse5": "^8.0.0",
    "rehype-raw": "^7.0.0",
    "remark-emoji": "^5.0.2",
    "remark-gfm": "^4.0.1",
    "remark-mdc": "^3.10.0",
    "remark-rehype": "^11.1.2",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "square": "^44.0.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@vueuse/core": "^14.2.1",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "pnpm@10.28.1"
}
