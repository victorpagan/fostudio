# Supabase — required. Set these in your hosting environment (e.g. Heroku config vars).
# @nuxtjs/supabase picks these up automatically.
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# Public app base URL used for auth email redirects (password reset, etc.)
NUXT_PUBLIC_SITE_URL=https://fo.studio

# Everything else (Square keys, location ID, app base URL, plan variation IDs, guest
# booking rates, etc.) is stored in Supabase and fetched at runtime via:
#   getKey(event, 'KEY_NAME')        → vault.secrets (encrypted)
#   getServerConfig(event, 'KEY')    → system_config table (plain jsonb)
#
# Seed system_config and vault.secrets via the Supabase dashboard or migrations.
# See supabase/migrations/ for the schema and seed SQL.

# Contact form delivery
# Configure either:
# 1) Resend (direct email delivery), or
# 2) A webhook endpoint (Zapier, Make, custom worker, etc.)
#
# Resend option
NUXT_RESEND_API_KEY=
NUXT_CONTACT_TO_EMAIL=
NUXT_CONTACT_FROM_EMAIL=
#
# Webhook fallback option
NUXT_CONTACT_WEBHOOK_URL=
#
# Public contact details shown on the site
NUXT_PUBLIC_CONTACT_EMAIL=studio@lafilmlab.com
NUXT_PUBLIC_CONTACT_PHONE=(323) 999-4300
NUXT_PUBLIC_CONTACT_LOCATION=LA Film Lab, 3131 N. San Fernando Rd., Los Angeles, CA 90065

# Nuxt Studio (content editing)
# Route in your app where Studio is mounted.
NUXT_STUDIO_ROUTE=/_studio
#
# Repository that Studio will read/write content to.
STUDIO_REPOSITORY_PROVIDER=github
STUDIO_REPOSITORY_OWNER=
STUDIO_REPOSITORY_REPO=
STUDIO_REPOSITORY_BRANCH=main
STUDIO_REPOSITORY_ROOT_DIR=
STUDIO_REPOSITORY_PRIVATE=true
#
# OAuth provider for Studio login (example: GitHub OAuth)
STUDIO_GITHUB_CLIENT_ID=
STUDIO_GITHUB_CLIENT_SECRET=
