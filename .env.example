# Public URL, used for OG Image when running nuxt generate
NUXT_PUBLIC_SITE_URL=

# App base URL (used for Square redirect URLs)
APP_BASE_URL=http://localhost:3000

# Square (stored in Supabase system_config via get_secret, not env — but useful for local dev)
# SQUARE_ENVIRONMENT=sandbox
# SQUARE_ACCESS_TOKEN=
# SQUARE_LOCATION_ID=
# SQUARE_WEBHOOK_SIGNATURE_KEY=   ← get from Square Developer → Webhooks → your endpoint
#
# Plan variation IDs (one per tier × cadence):
# SQUARE_PLAN_VARIATION_CREATOR_MONTHLY=
# SQUARE_PLAN_VARIATION_CREATOR_QUARTERLY=
# SQUARE_PLAN_VARIATION_CREATOR_ANNUAL=
# SQUARE_PLAN_VARIATION_PRO_MONTHLY=
# SQUARE_PLAN_VARIATION_PRO_QUARTERLY=
# SQUARE_PLAN_VARIATION_PRO_ANNUAL=
# SQUARE_PLAN_VARIATION_STUDIO_PLUS_MONTHLY=
# SQUARE_PLAN_VARIATION_STUDIO_PLUS_QUARTERLY=
# SQUARE_PLAN_VARIATION_STUDIO_PLUS_ANNUAL=

# Supabase (auto-injected by @nuxtjs/supabase — set in nuxt.config.ts runtimeConfig or here)
# SUPABASE_URL=
# SUPABASE_KEY=
# SUPABASE_SERVICE_KEY=
